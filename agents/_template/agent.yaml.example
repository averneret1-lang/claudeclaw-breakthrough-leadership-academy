# Agent configuration template.
# To add a new agent through the dashboard:
#   1. Copy this folder and rename it (e.g. "myagent")
#   2. Fill in the fields below
#   3. Add your bot token to .env: MYAGENT_BOT_TOKEN=xxx
#   4. Start with: npm start -- --agent myagent

name: My Agent
description: What this agent does

# The env var name in .env that holds this agent's Telegram bot token.
# Create a bot via @BotFather in Telegram (/newbot), paste the token into .env.
telegram_bot_token_env: MYAGENT_BOT_TOKEN

# Model options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
model: claude-sonnet-4-6
