agent_id: facilitator
name: Facilitator
telegram_bot_token: YOUR_TELEGRAM_BOT_TOKEN_HERE
allowed_users:
  - EUNOS_TELEGRAM_USER_ID_HERE
  - SAUREL_TELEGRAM_USER_ID_HERE
model: claude-sonnet-4-6
max_tokens: 2048
mcp_servers:
  - name: gdrive
    command: npx
    args: ["-y", "@modelcontextprotocol/server-gdrive"]
