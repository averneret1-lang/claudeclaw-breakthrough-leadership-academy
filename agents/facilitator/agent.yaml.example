name: Facilitator
description: Program facilitation — accessible by Eunos and Saurel for session ops
telegram_bot_token_env: FACILITATOR_BOT_TOKEN
model: claude-sonnet-4-6

# Facilitator is shared between Eunos and Saurel.
# Add both their Telegram IDs to FACILITATOR_ALLOWED_IDS in .env (comma-separated).
allowed_chat_ids_env: FACILITATOR_ALLOWED_IDS
