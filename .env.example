# Anthropic auth is handled via OAuth (claude auth login).
# Only set this if you prefer a raw API key instead.
# ANTHROPIC_API_KEY=

# Node environment
NODE_ENV=production

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# ── Mission Control Dashboard ──────────────────────────────────────────────────
# Web dashboard for monitoring agents, memory, missions, and logs.
# Token is auto-generated during install. Access via http://localhost:3141
DASHBOARD_TOKEN=
DASHBOARD_PORT=3141

# ── Agent Bot Tokens ───────────────────────────────────────────────────────────
# The installer sets up Alex (primary orchestrator) only.
# All other agents are activated through the Mission Control Dashboard.
# When you activate an agent in the dashboard, it will prompt you for the bot
# token and write it here automatically.
#
# To create a bot: open Telegram, message @BotFather, send /newbot.

# Primary orchestrator (filled in during install)
ALEX_BOT_TOKEN=

# Additional agents — filled in when activated via the dashboard
# GUERNSY_BOT_TOKEN=
# ANNE_CHRISTIE_BOT_TOKEN=
# ANGIE_BOT_TOKEN=
# FACILITATOR_BOT_TOKEN=
# BLTA_DANIEL_BOT_TOKEN=
# PARTICIPANT_INTEL_BOT_TOKEN=
# FULFILLMENT_COACH_BOT_TOKEN=
# ALUMNI_BOT_TOKEN=
# ANALYTICS_BOT_TOKEN=
# LEGAL_BOT_TOKEN=
# LIBRARIAN_BOT_TOKEN=

# Facilitator is shared by Eunos and Saurel.
# Paste both Telegram user IDs here, comma-separated (no spaces).
# Example: FACILITATOR_ALLOWED_IDS=123456789,987654321
# FACILITATOR_ALLOWED_IDS=

# Your Telegram user ID. Get it from https://t.me/userinfobot
ADMIN_TELEGRAM_ID=
