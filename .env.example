# Anthropic auth is handled via OAuth (claude auth login).
# Only set this if you prefer a raw API key instead.
# ANTHROPIC_API_KEY=

# Database encryption key — generated automatically by install.sh
# Must be a 64-character hex string. Do NOT share or commit.
DB_ENCRYPTION_KEY=

# Node environment
NODE_ENV=production

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# Path to this config repo — set automatically by install.sh
# The ClaudeClaw engine uses this to find agents/, .env, and store/
CLAUDECLAW_CONFIG=
