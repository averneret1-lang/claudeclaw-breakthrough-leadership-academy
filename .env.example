# Anthropic auth is handled via OAuth (claude auth login).
# Only set this if you prefer a raw API key instead.
# ANTHROPIC_API_KEY=

# Node environment
NODE_ENV=production

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# ── Mission Control Dashboard ──────────────────────────────────────────────────
# Web dashboard for monitoring agents, memory, missions, and logs.
# Token is auto-generated during install. Access via /gateway in Telegram.
DASHBOARD_TOKEN=
DASHBOARD_PORT=3141
